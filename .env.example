# PostgreSQL
POSTGRES_USER=ontario511
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ontario511_db
POSTGRES_PORT=5433

# Airflow
# Generate fresh values for AIRFLOW_FERNET_KEY and AIRFLOW_SECRET_KEY for
# this project - do not reuse keys from another deployment. Example:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   python3 -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme

# Airflow - email alerts (Gmail SMTP shown as an example; any SMTP provider works)
AIRFLOW_SMTP_USER=
AIRFLOW_SMTP_PASSWORD=
AIRFLOW_ALERT_EMAIL=

# Note: LLM provider API keys (Claude / OpenAI / Gemini) are NOT set here.
# They are entered directly in the dashboard's Chatbot tab at runtime and
# are never persisted to disk.
